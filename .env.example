# ===========================================
# INFLEX CMS - Environment Variables
# ===========================================

# Database (SQLite for dev, PostgreSQL for production)
DATABASE_URL="file:./dev.db"
# For production with Supabase/PostgreSQL:
# DATABASE_URL="postgresql://user:password@host:5432/inflex?schema=public"

# NextAuth.js
AUTH_SECRET="generate-with-openssl-rand-base64-32"
# Generate: openssl rand -base64 32

# Admin Credentials (for initial setup)
ADMIN_EMAIL="admin@inflex.id"
ADMIN_PASSWORD="change-this-strong-password"

# Vercel Blob Storage (for image uploads)
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxx"

# App URL
NEXTAUTH_URL="http://localhost:3000"
# For production: https://your-domain.com
